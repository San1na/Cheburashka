local function deepCopy(t)
    local c = {}
    for k, v in pairs(t) do
        c[k] = typeof(v) == "table" and deepCopy(v) or v
    end
    return c
end

local function create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props or {}) do
        inst[k] = v
    end
    return inst
end

local function makeCorner(parent, radius)
    return create("UICorner", { CornerRadius = UDim.new(0, radius), Parent = parent })
end

local function makeStroke(parent, color, t)
    return create("UIStroke", { Color = color, Thickness = 1, Transparency = t or 0, Parent = parent })
end

local function tween(obj, speed, props, style, dir)
    local tw = TweenService:Create(obj, TweenInfo.new(speed, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

local function textOfKey(key)
    if not key then return "None" end
    if key.EnumType == Enum.UserInputType then
        if key == Enum.UserInputType.MouseButton1 then return "LMB" end
        if key == Enum.UserInputType.MouseButton2 then return "RMB" end
        if key == Enum.UserInputType.MouseButton3 then return "MMB" end
    end
    return key.Name
end

local function getRoot(parent)
    if parent then return parent end
    local gui = Players.LocalPlayer:WaitForChild("PlayerGui"):FindFirstChild("AetherRoot")
    if gui then return gui end
    return create("ScreenGui", {
        Name = "AetherRoot",
        IgnoreGuiInset = true,
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Global,
        Parent = Players.LocalPlayer:WaitForChild("PlayerGui"),
    })
end

function Library.new(options)
    options = options or {}
    local self = setmetatable({}, Library)
    self.Settings = deepCopy(Library.Defaults)
    for k, v in pairs(options) do self.Settings[k] = v end
    self.Connections = {}
    self.Tabs = {}
    self.CurrentTab = nil
    self.Visible = true
    self._controls = {}
    self._order = {}
    self._destroyed = false
    self._config = nil
    self._pending = nil

    local s = self.Settings
    self.Root = getRoot(s.Parent)

    if s.BlurEnabled then
        local blur = Lighting:FindFirstChild("AetherBlur") or create("BlurEffect", { Name = "AetherBlur", Parent = Lighting })
        blur.Size = 0
        blur.Enabled = true
        self.Blur = blur
        tween(blur, s.AnimationSpeed, { Size = s.BlurSize }, Enum.EasingStyle.Quad)
    end

    self.Window = create("Frame", {
        Name = "Window",
        Size = UDim2.fromOffset(s.Width, s.Height),
        Position = UDim2.fromScale(0.5, 0.5),
        AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundColor3 = s.BackgroundColor,
        Parent = self.Root,
        ClipsDescendants = true,
    })
    makeCorner(self.Window, s.CornerRadius)
    makeStroke(self.Window, s.BorderColor, 0)

    local gradient = create("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 24, 35)),
            ColorSequenceKeypoint.new(1, s.BackgroundColor),
        }),
        Rotation = 105,
        Parent = self.Window,
    })

    local topGlow = create("Frame", {
        Size = UDim2.new(1, 0, 0, 80),
        BackgroundTransparency = 1,
        Parent = self.Window,
    })
    create("UIGradient", {
        Rotation = 90,
        Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 0.75), NumberSequenceKeypoint.new(1, 1) }),
        Color = ColorSequence.new({ ColorSequenceKeypoint.new(0, s.AccentColor2), ColorSequenceKeypoint.new(1, s.AccentColor) }),
        Parent = topGlow,
    })

    self.Sidebar = create("Frame", {
        Size = UDim2.new(0, 190, 1, 0),
        BackgroundTransparency = 1,
        Parent = self.Window,
    })

    create("Frame", {
        Size = UDim2.new(0, 1, 1, -20),
        Position = UDim2.fromOffset(189, 10),
        BorderSizePixel = 0,
        BackgroundColor3 = s.BorderColor,
        Parent = self.Sidebar,
    })

    local title = create("TextLabel", {
        Size = UDim2.new(1, -24, 0, 26),
        Position = UDim2.fromOffset(14, 14),
        BackgroundTransparency = 1,
        Text = s.Name,
        Font = Enum.Font.GothamBold,
        TextSize = s.TitleSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextColor3 = s.TextColor,
        Parent = self.Sidebar,
    })
    self.TitleLabel = title

    local subtitle = create("TextLabel", {
        Size = UDim2.new(1, -24, 0, 14),
        Position = UDim2.fromOffset(14, 42),
        BackgroundTransparency = 1,
        Text = s.Subtitle,
        Font = s.Font,
        TextSize = s.SmallTextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextColor3 = s.SubTextColor,
        Parent = self.Sidebar,
    })
    self.SubtitleLabel = subtitle

    local dots = create("Frame", {
        Size = UDim2.fromOffset(56, 10),
        Position = UDim2.fromOffset(14, 62),
        BackgroundTransparency = 1,
        Parent = self.Sidebar,
    })
    create("UIListLayout", { FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 6), Parent = dots })

    local function dot(color)
        local b = create("Frame", { Size = UDim2.fromOffset(10, 10), BackgroundColor3 = color, Parent = dots })
        makeCorner(b, 999)
        return b
    end

    local closeDot = dot(Color3.fromRGB(255, 90, 86))
    local minDot = dot(Color3.fromRGB(255, 189, 46))
    local hideDot = dot(Color3.fromRGB(39, 201, 63))

    self.TabsList = create("ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -86),
        Position = UDim2.fromOffset(0, 86),
        BackgroundTransparency = 1,
        CanvasSize = UDim2.fromOffset(0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 0,
        Parent = self.Sidebar,
    })
    create("UIListLayout", { Padding = UDim.new(0, 6), Parent = self.TabsList })

    self.Pages = create("Frame", {
        Size = UDim2.new(1, -190, 1, 0),
        Position = UDim2.fromOffset(190, 0),
        BackgroundTransparency = 1,
        Parent = self.Window,
        ClipsDescendants = true,
    })

    local drag = { active = false, start = nil, pos = nil }
    if s.Draggable then
        table.insert(self.Connections, self.Sidebar.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                drag.active = true
                drag.start = i.Position
                drag.pos = self.Window.Position
            end
        end))
        table.insert(self.Connections, UserInputService.InputChanged:Connect(function(i)
            if not drag.active then return end
            if i.UserInputType ~= Enum.UserInputType.MouseMovement and i.UserInputType ~= Enum.UserInputType.Touch then return end
            local delta = i.Position - drag.start
            self.Window.Position = UDim2.new(drag.pos.X.Scale, drag.pos.X.Offset + delta.X, drag.pos.Y.Scale, drag.pos.Y.Offset + delta.Y)
        end))
        table.insert(self.Connections, UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
                drag.active = false
            end
        end))
    end

    closeDot.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then self:Destroy() end
    end)
    hideDot.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then self:Toggle() end
    end)
    minDot.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            tween(self.Window, 0.22, { Size = UDim2.fromOffset(self.Settings.Width, 80) })
            task.delay(0.24, function()
                if self.Window and self.Window.Parent then
                    self.Pages.Visible = false
                    self.TabsList.Visible = false
                end
            end)
        end
    end)

    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(i, gpe)
        if gpe or UserInputService:GetFocusedTextBox() then return end
        local key = self.Settings.Keybind
        local hit = false
        if key.EnumType == Enum.KeyCode and i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode == key then hit = true end
        if key.EnumType == Enum.UserInputType and i.UserInputType == key then hit = true end
        if hit then self:Toggle() end
    end))

    local scale = create("UIScale", { Scale = 0.95, Parent = self.Window })
    self.Scale = scale
    self.Window.BackgroundTransparency = 1
    tween(scale, s.AnimationSpeed, { Scale = 1 }, Enum.EasingStyle.Back)
    tween(self.Window, s.AnimationSpeed, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quad)
    return self
end

function Library:_registerControl(flag, getter, setter)
    local base = tostring(flag or "control")
    local key = base
    local i = 1
    while self._controls[key] do
        i += 1
        key = base .. "_" .. i
    end
    self._controls[key] = { Get = getter, Set = setter }
    table.insert(self._order, key)
    if self._pending and self._pending[key] ~= nil then
        pcall(function() setter(self._pending[key], true) end)
    end
    return key
end

function Library:_emitChanged()
    if not self._config or not self._config.AutoSave then return end
    self._config.System:SaveConfig(self._config.AutoSaveName, self:GetValues())
    self._config.System:SetAutoLoad(self._config.AutoSaveName)
end

function Library:GetValues()
    local out = {}
    for _, key in ipairs(self._order) do
        local ref = self._controls[key]
        local ok, value = pcall(ref.Get)
        if ok then out[key] = value end
    end
    return out
end

function Library:ApplyValues(values, silent)
    for key, value in pairs(values or {}) do
        local ref = self._controls[key]
        if ref then pcall(function() ref.Set(value, silent == true) end) end
    end
end

function Library:BindConfigSystem(system, options)
    options = options or {}
    self._config = {
        System = system,
        AutoLoad = options.AutoLoad == true,
        AutoSave = options.AutoSave == true,
        AutoLoadName = options.AutoLoadName or "autoload",
        AutoSaveName = options.AutoSaveName or options.AutoLoadName or "autoload",
    }
    if self._config.AutoLoad then
        local data = system:LoadAutoLoad()
        if typeof(data) == "table" then
            self._pending = data
            self:ApplyValues(data, true)
        end
    end
end

function Library:SaveConfig(name)
    if not self._config then return false, "No config system" end
    return self._config.System:SaveConfig(name, self:GetValues())
end

function Library:LoadConfig(name)
    if not self._config then return false, "No config system" end
    local data = self._config.System:LoadConfig(name)
    if typeof(data) ~= "table" then return false, "Config not found" end
    self:ApplyValues(data, true)
    return true
end

function Library:SetVisible(state)
    self.Visible = state
    if state then
        self.Window.Visible = true
        self.Window.BackgroundTransparency = 1
        self.Scale.Scale = 0.95
        if self.Blur then tween(self.Blur, 0.2, { Size = self.Settings.BlurSize }, Enum.EasingStyle.Quad) end
        tween(self.Scale, self.Settings.AnimationSpeed, { Scale = 1 }, Enum.EasingStyle.Back)
        tween(self.Window, self.Settings.AnimationSpeed, { BackgroundTransparency = 0 }, Enum.EasingStyle.Quad)
    else
        if self.Blur then tween(self.Blur, 0.2, { Size = 0 }, Enum.EasingStyle.Quad) end
        tween(self.Scale, 0.16, { Scale = 0.95 }, Enum.EasingStyle.Quad)
        tween(self.Window, 0.16, { BackgroundTransparency = 1 }, Enum.EasingStyle.Quad)
        task.delay(0.17, function()
            if self.Window and self.Window.Parent and not self.Visible then
                self.Window.Visible = false
            end
        end)
    end
end

function Library:Toggle()
    if not self.Window then return end
    if not self.Pages.Visible and self.Visible then
        self.Pages.Visible = true
        self.TabsList.Visible = true
        tween(self.Window, 0.2, { Size = UDim2.fromOffset(self.Settings.Width, self.Settings.Height) })
    else
        self:SetVisible(not self.Visible)
    end
end

