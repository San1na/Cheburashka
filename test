                Size = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = s.AccentColor,
                Parent = bar,
            })
            makeCorner(fill, 999)
            local knob = create("Frame", {
                Size = UDim2.fromOffset(14, 14),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                BackgroundColor3 = Color3.new(1, 1, 1),
                Parent = fill,
            })
            makeCorner(knob, 999)
            local function render(v)
                local alpha = (v - min) / math.max(max - min, 1)
                fill.Size = UDim2.new(math.clamp(alpha, 0, 1), 0, 1, 0)
                valueLabel.Text = tostring(v)
            end
            local function set(raw, silent)
                local rounded = min + math.floor(((raw - min) / step) + 0.5) * step
                value = math.clamp(rounded, min, max)
                render(value)
                if data.Callback then data.Callback(value) end
                if not silent then menuRef:_emitChanged() end
            end
            local controlKey = menuRef:_registerControl(data.Flag or data.Text or "slider", function() return value end, set)
            local hit = create("TextButton", {
                Size = UDim2.new(1, 0, 1, 16),
                Position = UDim2.fromOffset(0, -8),
                BackgroundTransparency = 1,
                Text = "",
                Parent = bar,
